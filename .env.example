# =====================================
# Energy Operations Intelligence Platform
# Environment Variables
# =====================================

# Application
APP_NAME=Energy Operations Intelligence Platform
APP_ENV=development
APP_VERSION=0.1.0

# Logging
LOG_LEVEL=INFO

# Random Seed
RANDOM_SEED=42

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=energy_operations
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# Streamlit
STREAMLIT_SERVER_PORT=8501

# API
API_HOST=0.0.0.0
API_PORT=8000
